<?xml version="1.0" encoding="UTF-8"?>
<!-- WiX 3.x — candle/light + WixUIExtension. Variables: ProductVersion, HwtwExe, ReqTxt, IconIco -->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
      Id="*"
      Name="HWTW (Holo Wind Tunnel GUI)"
      Language="1033"
      Version="$(var.ProductVersion)"
      Manufacturer="https://github.com/ta10101/HWTW"
      UpgradeCode="A8F9E7D6-5C4B-3A21-9F8E-7D6C5B4A3F2E">
    <!-- Package must be the first child of Product (WiX 3). License RTF lives in a Fragment. -->
    <Package
        InstallerVersion="500"
        Compressed="yes"
        InstallScope="perMachine"
        Platform="x64"
        Description="Desktop helper for Holochain Wind Tunnel (Docker)"
        Comments="Not affiliated with Holo or Holochain Foundation." />
    <MajorUpgrade DowngradeErrorMessage="A newer version of HWTW is already installed." />
    <MediaTemplate EmbedCab="yes" />
    <Icon Id="IconHWTW" SourceFile="$(var.IconIco)" />
    <Property Id="ARPPRODUCTICON" Value="IconHWTW" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <UIRef Id="WixUI_FeatureTree" />
    <Feature
        Id="MainFeature"
        Title="HWTW (Holo Wind Tunnel GUI)"
        Level="1"
        Display="expand"
        ConfigurableDirectory="INSTALLFOLDER">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentRef Id="cmpStartMenuShortcut" />
      <Feature
          Id="DesktopShortcutFeature"
          Title="Desktop shortcut"
          Description="Adds an HWTW icon to the shared (public) desktop. On Custom setup you can turn this off."
          Level="1"
          Display="expand"
          AllowAdvertise="no">
        <ComponentRef Id="cmpDesktopShortcut" />
      </Feature>
    </Feature>
  </Product>

  <!-- WixUILicenseRtf is set at link time (light -dWixUILicenseRtf=...) so the path resolves on CI. -->

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="HWTW" />
      </Directory>
      <Directory Id="CommonProgramsFolder">
        <Directory Id="ApplicationProgramsFolder" Name="HWTW" />
      </Directory>
    </Directory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="cmpHWTWexe" Guid="*">
        <File Id="filHWTWexe" Source="$(var.HwtwExe)" KeyPath="yes" />
      </Component>
      <Component Id="cmpRequirements" Guid="*">
        <File Id="filRequirements" Source="$(var.ReqTxt)" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="cmpStartMenuShortcut" Guid="*">
        <Shortcut
            Id="scHWTWStartMenu"
            Name="HWTW"
            Description="Holo Wind Tunnel GUI"
            Target="[#filHWTWexe]"
            WorkingDirectory="INSTALLFOLDER"
            Icon="IconHWTW" />
        <!-- Runs Windows Installer remove for this product (same as Settings → Apps → Uninstall). -->
        <Shortcut
            Id="scUninstallHWTW"
            Name="Uninstall HWTW"
            Description="Remove HWTW from this PC"
            Target="[System64Folder]msiexec.exe"
            Arguments="/x [ProductCode]" />
        <RemoveFolder Id="RemoveHWTWProgramsFolder" On="uninstall" />
        <RegistryValue
            Root="HKLM"
            Key="Software\ta10101\HWTW"
            Name="StartMenuShortcut"
            Type="integer"
            Value="1"
            KeyPath="yes" />
      </Component>
    </DirectoryRef>
  </Fragment>

  <Fragment>
    <!-- WiX 3: use CommonDesktopFolder (all-users desktop). PublicDesktopFolder is not a standard symbol → LGHT0094. -->
    <DirectoryRef Id="CommonDesktopFolder">
      <Component Id="cmpDesktopShortcut" Guid="*">
        <Shortcut
            Id="scHWTWDesktop"
            Name="HWTW"
            Description="Holo Wind Tunnel GUI"
            Target="[#filHWTWexe]"
            WorkingDirectory="INSTALLFOLDER"
            Icon="IconHWTW" />
        <RegistryValue
            Root="HKLM"
            Key="Software\ta10101\HWTW"
            Name="DesktopShortcut"
            Type="integer"
            Value="1"
            KeyPath="yes" />
      </Component>
    </DirectoryRef>
  </Fragment>
</Wix>
